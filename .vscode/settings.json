{
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda",

      // 全局启用
  "background.enabled": true,

  // 编辑器背景
  "background.editor": {
    "useFront": true,
    "images": [
      // 本地图（Windows 示例）
      //"/Users/azusa/Pictures/4E8CF423C2F2CB0065EED5C6027E3E00.png",
      // 在线图（必须 https）
      "https://xxx.com/xxx.jpg"
    ],
    "style": {
      "opacity": 0.3,
      "background-size": "cover",
      "background-position": "center"
    },
    "interval": 0,    // 轮播秒数，0 不轮播
    "random": false   // 是否随机
  },

  // 全屏背景（和编辑器二选一即可）
  "background.fullscreen": {
    "images": ["D:\\Picture\\4E8CF423C2F2CB0065EED5C6027E3E00.png"],
    "opacity": 0.15,
    "size": "cover",
    "position": "center"
  }
}
